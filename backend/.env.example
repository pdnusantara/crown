# ─────────────────────────────────────────────────────────────────────────────
# SembaPOS / Crown — contoh konfigurasi backend.
# Salin ke `.env` lalu isi nilai produksi. JANGAN commit `.env` asli.
# ─────────────────────────────────────────────────────────────────────────────

# ── Wajib ────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/crown_db"

# Rahasia JWT — di produksi WAJIB di-set & kuat (boot akan gagal bila kosong saat
# NODE_ENV=production). Buat dengan: openssl rand -hex 48
JWT_SECRET="change-this-in-production"
JWT_REFRESH_SECRET="change-this-too"

PORT=3001
NODE_ENV=development                    # 'production' di server

# URL frontend — dipakai untuk CORS (exact match + subdomain) & CORS Socket.io.
FRONTEND_URL="http://localhost:5173"

# ── Domain & host publik ─────────────────────────────────────────────────────
APP_BASE_DOMAIN="sembapos.com"          # domain dasar; subdomain = slug tenant
BACKEND_URL="https://sembapos.com"      # dasar URL absolut (callback Duitku, dll); default FRONTEND_URL
PUBLIC_HOST="sembapos.com"              # host publik untuk tautan (struk/booking)

# ── Lokal & waktu ────────────────────────────────────────────────────────────
REPORT_TZ="Asia/Jakarta"               # zona waktu default laporan (fallback Tenant.timezone)

# ── Langganan & billing ──────────────────────────────────────────────────────
TRIAL_DAYS=14                          # lama trial tenant baru (hari)
SUBSCRIPTION_GRACE_DAYS=7              # masa tenggang setelah jatuh tempo (hari)
PAYMENT_ORDER_TTL_MINUTES=60          # umur order pembayaran sebelum kedaluwarsa (menit)
MAX_PAUSE_DAYS=30                     # maksimal jeda langganan (hari)
AFFILIATE_MIN_PAYOUT=100000          # ambang minimum payout afiliasi (Rupiah)

# Catatan: kredensial Duitku (merchant code, API key, sandbox/produksi) disimpan
# di tabel SystemSetting (duitku_*), dikelola lewat panel super-admin — BUKAN env.

# ── Telegram (alert error & notifikasi pendaftaran) ──────────────────────────
# Opsional. Bisa diisi via env ATAU panel (SystemSetting telegram_*). Bila kedua
# kosong, notifikasi & alert error backend nonaktif (best-effort, tak blok app).
TELEGRAM_BOT_TOKEN=""                  # token bot dari @BotFather
TELEGRAM_CHAT_ID=""                    # id grup/chat tujuan alert

# ── WhatsApp (Beta) — provider: WA Gateway (wagat.web.id, berbasis Baileys) ──
# Sesi WhatsApp dijalankan di gateway eksternal; server utama tidak menjalankan
# Chrome sama sekali. Satu API key dipakai bersama; tiap tenant Crown punya
# satu device sendiri di akun wagat tersebut. WAGAT_API_KEY WAJIB diisi.
WAGAT_API_KEY=""                        # API key akun wagat (format: wag_xxxxxxxx)
WAGAT_WEBHOOK_SECRET=""                 # secret verifikasi HMAC webhook status WA
# WAGAT_BASE_URL="https://wagat.web.id/api/v1"  # opsional, override base URL
# WAGAT_TIMEOUT_MS=15000                # timeout tiap panggilan ke gateway (ms)

# ── Dev only ─────────────────────────────────────────────────────────────────
# DEV_LOGIN=1                           # login tanpa password per-subdomain.
                                        # JANGAN AKTIF DI PRODUKSI.
