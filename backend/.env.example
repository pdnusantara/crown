DATABASE_URL="postgresql://user:password@localhost:5432/barberos"
JWT_SECRET="change-this-in-production"
JWT_REFRESH_SECRET="change-this-too"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# WhatsApp (Beta — whatsapp-web.js + Puppeteer)
# Setiap tenant aktif = satu instance Chrome. Sesuaikan dengan kapasitas mesin.
# WA_MAX_CLIENTS=8                  # batas tenant aktif bersamaan
# WA_IDLE_TIMEOUT_MINUTES=30        # 0 = nonaktif; selain 0, client di-sleep setelah idle
# WA_RECONNECT_WAIT_SECONDS=25      # batas waktu wake-up sebelum kirim notif
# WA_CHROME_PATH=/usr/bin/chromium  # opsional, override binary Chrome
