DATABASE_URL="postgresql://user:password@localhost:5432/barberos"
JWT_SECRET="change-this-in-production"
JWT_REFRESH_SECRET="change-this-too"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# WhatsApp (Beta) — provider: WA Gateway (wagat.web.id, berbasis Baileys)
# Sesi WhatsApp dijalankan di gateway eksternal; server utama tidak menjalankan
# Chrome sama sekali. Satu API key dipakai bersama; tiap tenant Crown punya
# satu device sendiri di akun wagat tersebut. WAGAT_API_KEY WAJIB diisi.
WAGAT_API_KEY=""                        # API key akun wagat (format: wag_xxxxxxxx)
# WAGAT_BASE_URL="https://wagat.web.id/api/v1"  # opsional, override base URL
# WAGAT_TIMEOUT_MS=15000                # timeout tiap panggilan ke gateway
