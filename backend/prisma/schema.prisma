generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  tenant_admin
  kasir
  barber
  customer
  affiliate
}

enum SubscriptionStatus {
  trial
  active
  overdue
  expired
  paused
}

enum BillingCycle {
  monthly
  annual
}

enum SubscriptionPackage {
  Basic
  Pro
  Enterprise
}

enum BranchAddonType {
  monthly
  onetime
}

enum TicketStatus {
  open
  in_progress
  resolved
}

enum TicketPriority {
  low
  medium
  high
}

enum QueueStatus {
  waiting
  in_progress
  done
  paid
  cancelled
}

enum QueueType {
  walk_in
  booking
}

enum BookingStatus {
  pending
  confirmed
  in_progress
  done
  cancelled
}

enum BookingSource {
  online // dibuat oleh pelanggan via halaman publik / aplikasi customer
  walk_in // diinput langsung oleh kasir di counter
}

enum TransactionStatus {
  completed
  cancelled
  refunded
}

enum ShiftStatus {
  open
  closed
}

enum BroadcastType {
  info
  warning
  error
  success
}

enum PaymentMethod {
  cash
  transfer
  qris
  card
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String
  role           Role
  phone          String?
  photo          String?
  commissionRate Float          @default(0.35)
  // Skema gaji barber: 'commission' (% omzet) | 'fixed' (gaji pokok bulanan)
  // | 'hybrid' (gaji pokok + komisi). baseSalary = gaji pokok per bulan (Rp).
  salaryType     String         @default("commission")
  baseSalary     Int            @default(0)
  // Kasir/admin yang juga melayani sebagai barber (toko kecil, 1 orang
  // merangkap). Bila true, user ikut muncul di daftar/pilihan barber POS
  // sehingga komisi & rating-nya tercatat — tanpa perlu akun barber terpisah.
  isBarber       Boolean        @default(false)
  tenantId       String?
  branchId       String?
  isActive       Boolean        @default(true)
  // True bila staf dibuat di atas kuota paket & menunggu pembayaran add-on.
  // Selama true, isActive dipaksa false (tak bisa login) sampai invoice
  // staff_addon terkait lunas → keduanya direset saat pembayaran masuk.
  lockedPendingAddon Boolean    @default(false)
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenant         Tenant?        @relation(fields: [tenantId], references: [id])
  branch         Branch?        @relation(fields: [branchId], references: [id])
  refreshTokens  RefreshToken[]
  ratings        BarberRating[] @relation("BarberRatings")
  ticketsCreated Ticket[]
  ticketReplies  TicketReply[]
  attendances    Attendance[]
  workSchedules  WorkSchedule[]
  // Item transaksi dengan barber ini di-assign — dipakai untuk lookup nama
  // barber di /kasir/transactions & laporan komisi.
  transactionItemsAsBarber TransactionItem[] @relation("BarberItems")
  // Profil affiliate — diisi hanya untuk user role=affiliate. 1-1 dengan User
  // supaya self-service dashboard cukup join via req.user.id.
  affiliate      Affiliate?     @relation("UserAffiliate")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tenant {
  id                  String               @id @default(cuid())
  name                String
  slug                String?              @unique
  email               String               @unique
  phone               String?
  address             String?
  logo                String?
  // Tax / billing identity — dipakai di faktur & metadata Duitku.
  companyName         String?
  npwp                String?
  taxAddress          String?
  // Timezone IANA (mis. "Asia/Jakarta", "Asia/Makassar", "Asia/Jayapura").
  // Dipakai untuk format tanggal & grouping laporan harian agar konsisten
  // antar viewer (kasir di Jakarta vs admin di laptop saat di luar negeri).
  timezone            String               @default("Asia/Jakarta")
  // Konfigurasi tampilan halaman booking publik (/book) — disimpan sebagai
  // JSON agar field-field marketing (tagline, hero image, gallery, sosmed)
  // bisa diperluas tanpa migrasi schema setiap kali.
  bookingPage         Json?
  // Wilayah fokus toko { provinsiId, provinsi, kabupatenId, kabupaten } —
  // acuan Laporan Wilayah & pemilih kecamatan/desa di kasir & booking.
  wilayah             Json?
  // Teks/pesan otomatis setelah transaksi { waCustomerMessage, waShareMessage }.
  // waCustomerMessage = pembuka notifikasi WA otomatis ke pelanggan;
  // waShareMessage    = penutup pesan WA yang dibagikan kasir dari struk.
  // Mendukung placeholder {nama} (nama pelanggan) & {toko} (nama tenant).
  transactionMessages Json?
  // Pengingat kunjungan otomatis via WhatsApp untuk pelanggan yang sudah lama
  // tak datang. { enabled, inactiveDays, repeat, sendHour, message }.
  //   inactiveDays = ambang hari tanpa kunjungan
  //   repeat       = true: kirim ulang tiap inactiveDays | false: sekali saja
  //   sendHour     = jam (0-23, zona waktu tenant) job dijalankan
  //   message      = teks pesan, placeholder {nama} {toko} {hari}
  visitReminder       Json?
  // Konfigurasi absensi digital staf (kasir & barber) — disimpan JSON agar
  // bisa diperluas tanpa migrasi.
  //   lateToleranceMin = toleransi menit sebelum dihitung terlambat
  //   autoCheckOut     = true: job menutup absen yang lupa di-checkout
  //   maxAccuracyM     = akurasi GPS maksimum (meter) yang diterima
  //   requireSelfie    = true: staf wajib unggah foto selfie saat check-in/out
  attendanceConfig    Json?
  // Preset shift untuk /admin/schedule. Array {value,startTime,endTime}.
  // Bila null → frontend pakai default Pagi/Sore/Full.
  shiftPresets        Json?
  // Konfigurasi rating otomatis via WhatsApp setelah transaksi.
  // { enabled, autoSendMinutes, messageTemplate }
  //   enabled            = aktifkan kirim link rating otomatis ke pelanggan
  //   autoSendMinutes    = delay sebelum link dikirim (default 15 menit)
  //   messageTemplate    = teks pesan, placeholder {nama} {toko} {link}
  ratingConfig        Json?
  // Atribusi pendaftaran — dari mana tenant ini datang saat /register.
  //   signupChannel = kanal ternormalisasi untuk grouping cepat di laporan:
  //     'facebook_ads' | 'google_ads' | 'campaign' | 'referral' | 'direct'.
  //     Sumber affiliate ditentukan terpisah lewat relasi affiliateReferral.
  //   signupMeta    = data mentah { utmSource, utmMedium, utmCampaign,
  //     utmContent, utmTerm, fbclid, gclid, referrer, landingPath, ref }.
  signupChannel       String?
  signupMeta          Json?
  isSuspended         Boolean              @default(false)
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  branches            Branch[]
  users               User[]
  services            Service[]
  customers           Customer[]
  vouchers            Voucher[]
  subscription        Subscription?
  featureFlags        TenantFeatureFlag[]
  tickets             Ticket[]
  broadcasts          BroadcastRecipient[]
  expenses            Expense[]
  attendances         Attendance[]
  workSchedules       WorkSchedule[]
  // Referral mitra affiliate yang merekrut tenant ini (kalau ada). Nullable —
  // mayoritas tenant tidak datang dari affiliate. Disetel saat /auth/register
  // bila request membawa referralCode valid.
  affiliateReferral   AffiliateReferral?
}

model Branch {
  id               String        @id @default(cuid())
  tenantId         String
  // Kode pendek per cabang dipakai di URL (mis. "main", "cab1") — unik per tenant.
  // Nullable supaya branch lama tetap valid sebelum di-backfill.
  code             String?
  name             String
  address          String?
  phone            String?
  openTime         String        @default("09:00")
  closeTime        String        @default("21:00")
  // Titik koordinat cabang untuk geofence absensi digital. Staf hanya bisa
  // check-in bila berada dalam radius `attendanceRadius` meter dari titik ini.
  // Null = absensi belum dikonfigurasi untuk cabang ini.
  latitude         Float?
  longitude        Float?
  attendanceRadius Int           @default(100)
  // Tanggal-tanggal cabang tutup (libur Lebaran, cuti bersama, dst).
  // Array of {date: "YYYY-MM-DD", note?: string}. Maks 365 entri.
  closedDates      Json?
  // Wilayah BPS per-cabang (provinsi+kabupaten) — dipakai WilayahPicker di
  // POS/booking sebagai default kecamatan/desa untuk pelanggan baru. Bila null,
  // fallback ke Tenant.wilayah. Shape sama: {provinsiId, provinsi, kabupatenId,
  // kabupaten}. Cabang di provinsi berbeda dgn HQ (mis. Jakarta vs HQ Kuningan)
  // pakai field ini supaya pelanggan barunya tidak terdaftar di JABAR.
  wilayah          Json?
  isActive         Boolean       @default(true)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users            User[]
  transactions     Transaction[]
  queues           Queue[]
  bookings         Booking[]
  shifts           Shift[]
  expenses         Expense[]
  attendances      Attendance[]

  @@unique([tenantId, code])
}

model Service {
  id               String            @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  price            Int
  duration         Int
  category         String
  icon             String?
  isActive         Boolean           @default(true)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactionItems TransactionItem[]
}

model Customer {
  id             String         @id @default(cuid())
  tenantId       String
  name           String
  phone          String
  email          String?
  gender         String?
  birthDate      DateTime?
  address        Json?
  loyaltyPoints  Int            @default(0)
  visitCount     Int            @default(0)
  notes          String?
  // Kapan pengingat kunjungan WhatsApp terakhir dikirim ke pelanggan ini —
  // dipakai job visitReminder untuk cegah pesan berulang/spam.
  lastReminderAt DateTime?
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  bookings       Booking[]
  pointHistory   PointHistory[]
}

// Ledger imutabel pergerakan loyalty points — single source of truth untuk
// audit & rekonsiliasi. Saldo Customer.loyaltyPoints harus = SUM(delta) di
// ledger ini. Type:
//   - earn:   poin otomatis dari transaksi POS
//   - adjust: penyesuaian manual admin (positif/negatif) — reason wajib
//   - redeem: poin dipakai (future)
//   - expire: poin kadaluwarsa (future)
model PointHistory {
  id           String   @id @default(cuid())
  tenantId     String
  customerId   String
  delta        Int // positif = nambah, negatif = kurang
  balanceAfter Int // snapshot saldo SETELAH operasi → audit-friendly
  type         String // 'earn' | 'adjust' | 'redeem' | 'expire'
  reason       String? // konteks (mis. "kompensasi keluhan", "ulang tahun")
  refType      String? // 'transaction' | 'admin' | 'system'
  refId        String? // id transaksi atau user yang adjust
  actorId      String? // user id yang melakukan adjust manual (null untuk auto)
  createdAt    DateTime @default(now())
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId, createdAt])
  @@index([customerId, createdAt])
}

model Transaction {
  id                  String            @id @default(cuid())
  tenantId            String
  branchId            String
  customerId          String?
  // Snapshot identitas pelanggan — diisi saat walk-in tanpa registrasi atau
  // saat customer record kemudian dihapus, supaya struk & laporan tetap utuh.
  customerName        String?
  customerPhone       String?
  shiftId             String?
  // Diisi kalau transaksi berasal dari booking (customer reservasi sebelumnya).
  // Kosong untuk walk-in murni di counter. Index agar query "transaksi per
  // booking" cepat.
  bookingId           String?
  subtotal            Int
  discountType        String?
  discountValue       Int               @default(0)
  discountAmount      Int               @default(0)
  tax                 Int               @default(0)
  total               Int
  paymentMethod       PaymentMethod     @default(cash)
  cashReceived        Int?
  change              Int?
  // Poin loyalti yang ditukar oleh pelanggan pada transaksi ini. Nilai diskonnya
  // sudah masuk di `discountAmount`. Disimpan terpisah supaya laporan bisa
  // memisahkan "diskon dari poin" vs "diskon manual/voucher".
  pointsRedeemed      Int               @default(0)
  // Poin loyalti yang DIPEROLEH pelanggan dari transaksi ini. Disimpan agar
  // bisa di-reverse persis saat transaksi dibatalkan / refund.
  loyaltyPointsEarned Int               @default(0)
  // Kode voucher yang dipakai (kalau ada) — disimpan supaya usedCount voucher
  // bisa dikembalikan saat transaksi dibatalkan.
  voucherCode         String?
  status              TransactionStatus @default(completed)
  // Timestamp WA rating link dikirim ke pelanggan — null = belum dikirim.
  // Cron `ratingLinkDispatch` pakai field ini untuk hindari kirim dobel.
  ratingLinkSentAt    DateTime?
  createdAt           DateTime          @default(now())
  branch              Branch            @relation(fields: [branchId], references: [id])
  customer            Customer?         @relation(fields: [customerId], references: [id])
  shift               Shift?            @relation(fields: [shiftId], references: [id])
  booking             Booking?          @relation(fields: [bookingId], references: [id])
  items               TransactionItem[]

  @@index([bookingId])
  @@index([branchId, createdAt])
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String
  serviceId     String
  barberId      String?
  name          String
  price         Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])
  // Relasi opsional ke barber yang melayani item ini — supaya prisma include
  // bisa fetch nama tanpa N+1.
  barber        User?       @relation("BarberItems", fields: [barberId], references: [id])
}

model Queue {
  id            String      @id @default(cuid())
  tenantId      String
  branchId      String
  customerId    String?
  customerName  String
  customerPhone String?
  serviceId     String?
  serviceNames  String? // pipe-separated names (denormalized for now; pivot table if needed later)
  barberId      String?
  barberName    String?
  type          QueueType   @default(walk_in)
  queueNumber   Int
  status        QueueStatus @default(waiting)
  notes         String?
  estimatedTime Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  branch        Branch      @relation(fields: [branchId], references: [id])
}

model Booking {
  id            String        @id @default(cuid())
  tenantId      String
  branchId      String
  customerId    String?
  customerName  String
  customerPhone String
  // serviceId/serviceName = layanan PERTAMA (kompat mundur & tampilan ringkas).
  // serviceIds = daftar lengkap layanan yang dipilih (booking bisa >1 layanan);
  // serviceName diisi gabungan nama ("Potong + Cuci"). Durasi = jumlah durasi.
  serviceId     String?
  serviceName   String?
  serviceIds    String[]      @default([])
  barberId      String?
  barberName    String?
  date          String
  time          String
  status        BookingStatus @default(pending)
  // Asal pembuatan booking — supaya kasir bisa membedakan booking online
  // (dari halaman publik / aplikasi customer) dengan booking walk-in
  // (diinput langsung kasir di counter).
  source        BookingSource @default(online)
  notes         String?
  createdAt     DateTime      @default(now())
  branch        Branch        @relation(fields: [branchId], references: [id])
  customer      Customer?     @relation(fields: [customerId], references: [id])
  transactions  Transaction[]

  @@index([tenantId, branchId, date])
  @@index([branchId, status])
}

model Voucher {
  id          String    @id @default(cuid())
  tenantId    String
  code        String
  description String?
  type        String
  value       Int
  minPurchase Int       @default(0)
  maxUses     Int?
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
}

// Pengeluaran operasional tenant — gaji, sewa, supplies, dll. Dipakai halaman
// /admin/expenses untuk hitung laba bersih (pemasukan transaksi − biaya).
model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  category    String
  description String
  amount      Int
  // Tanggal kalender pengeluaran, disimpan UTC-midnight agar filter periode
  // konsisten lintas timezone (lihat catatan di routes/expenses.js).
  date        DateTime
  // Barber terkait — diisi saat pengeluaran dibuat dari fitur "Gaji Barber"
  // (penanda agar komisi tak dobel dicatat). Kolom skalar, tanpa FK.
  barberId    String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId, date])
  @@index([tenantId, category])
}

model Package {
  name                  SubscriptionPackage @id
  price                 Int
  maxBranches           Int                 @default(1)
  // Total staf (TERMASUK owner/admin) yang sudah include di paket. Lebih dari
  // ini kena tarif add-on per staf (staffAddonPrice × staffAddonType monthly/
  // onetime). 2026-05-28 default 5→4 (Basic 4, Pro 15, Enterprise 999 set via
  // UPDATE saat rollout). Reuse enum BranchAddonType untuk konsistensi.
  maxStaff              Int                 @default(4)
  // Bonus staf otomatis untuk SETIAP cabang add-on yang sudah paid.
  // effectiveMaxStaff = maxStaff + (paidBranchAddonCount × staffPerExtraBranch)
  // Mis. Basic +3 → 1 cabang = 4 staf, 2 cabang = 7 staf, 3 cabang = 10 staf.
  // Pro +5 → 1 cabang = 15, 2 cabang = 20, dst.
  staffPerExtraBranch   Int                 @default(0)
  staffAddonPrice       Int                 @default(0)
  staffAddonType        BranchAddonType     @default(monthly)
  branchAddonPrice      Int                 @default(0)
  branchAddonType       BranchAddonType     @default(monthly)
  // Diskon untuk pembayaran tahunan (% dari harga 12 bulan). Default 17 ≈ 2 bulan gratis.
  annualDiscountPercent Int                 @default(17)
  description           String?
  features              String[]            @default([])
  updatedAt             DateTime            @updatedAt
}

model Subscription {
  id           String              @id @default(cuid())
  tenantId     String              @unique
  package      SubscriptionPackage @default(Basic)
  status       SubscriptionStatus  @default(trial)
  price        Int
  billingCycle BillingCycle        @default(monthly)
  startDate    DateTime
  endDate      DateTime
  autoRenew    Boolean             @default(true)
  // Pause window — saat status=paused, cron auto-renew di-skip dan endDate akan
  // diperpanjang sebesar (pauseUntil - pausedAt) saat resume.
  pausedAt     DateTime?
  pauseUntil   DateTime?
  pauseReason  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
}

model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String
  period         String
  amount         Int
  // Untuk audit & faktur: nilai sebelum diskon (kalau ada promo/annual).
  originalAmount Int?
  discountAmount Int           @default(0)
  promotionCode  String?
  billingCycle   BillingCycle?
  type           String        @default("subscription")
  status         String        @default("pending")
  // Jumlah unit yang ditagih dalam 1 invoice. Default 1 (kompatibel data lama
  // dan invoice subscription). Untuk invoice add-on aggregate, mis. 3 cabang
  // ekstra dalam 1 invoice → quantity=3, amount = 3 × addonPrice. Dipakai
  // license counting (SUM quantity, bukan COUNT).
  quantity       Int           @default(1)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  // Untuk invoice staff_addon: staf yang dibuat terkunci menunggu pembayaran
  // ini. Saat invoice lunas, user tsb diaktifkan otomatis. Null untuk tipe lain.
  staffUserId    String?
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model TenantFeatureFlag {
  id       String  @id @default(cuid())
  tenantId String
  flagId   String
  enabled  Boolean @default(false)
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, flagId])
}

model Ticket {
  id          String         @id @default(cuid())
  tenantId    String
  subject     String
  description String
  category    String
  priority    TicketPriority @default(medium)
  status      TicketStatus   @default(open)
  attachments String[]       @default([]) // URL gambar lampiran (relatif: /api/uploads/tickets/...)
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User           @relation(fields: [createdById], references: [id])
  replies     TicketReply[]
}

model TicketReply {
  id          String   @id @default(cuid())
  ticketId    String
  authorId    String
  message     String
  isAdmin     Boolean  @default(false)
  attachments String[] @default([]) // URL gambar lampiran (relatif: /api/uploads/tickets/...)
  createdAt   DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])
}

model Broadcast {
  id         String               @id @default(cuid())
  title      String
  message    String
  type       BroadcastType        @default(info)
  active     Boolean              @default(true)
  sentAt     DateTime             @default(now())
  recipients BroadcastRecipient[]
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  tenantId    String
  isRead      Boolean   @default(false)
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, tenantId])
}

// BarberSchedule = jadwal kerja barber per tenggat hari (bukan shift kasir).
// Disimpan di server supaya admin lain bisa lihat, barber bisa cek jadwalnya
// sendiri, dan laporan jam kerja akurat.
model BarberSchedule {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  staffId   String
  date      String // "YYYY-MM-DD" tenant-local — sama format seperti Booking.date
  shift     String // 'Pagi' | 'Sore' | 'Full' — label simbolik utk preset
  startTime String // "HH:MM"
  endTime   String // "HH:MM"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, date])
  @@index([staffId, date])
}

model Shift {
  id                String        @id @default(cuid())
  branchId          String
  kasirId           String
  // Snapshot nama kasir saat shift dibuka — supaya audit trail tetap valid
  // walau user di-rename atau di-deactivate.
  kasirName         String?
  status            ShiftStatus   @default(open)
  openedAt          DateTime      @default(now())
  closedAt          DateTime?
  // Kas drawer reconciliation — semua nullable supaya kompatibel dengan
  // data lama yang belum diisi.
  openingCash       Int?          @default(0)
  closingCash       Int?
  expectedCash      Int?
  cashDifference    Int?
  notes             String?
  totalRevenue      Int?
  totalTransactions Int?
  branch            Branch        @relation(fields: [branchId], references: [id])
  transactions      Transaction[]

  @@index([branchId, status])
  @@index([kasirId, status])
}

// Rating per barber yang diberikan customer (via kasir) saat selesai transaksi.
// Dedup constraint: 1 barber hanya bisa di-rate sekali per transaksi.
model BarberRating {
  id            String    @id @default(cuid())
  tenantId      String? // null untuk legacy data sebelum migrasi 2026-05-15
  branchId      String? // opsional, untuk filter per cabang di laporan
  barberId      String
  transactionId String? // null kalau rating diberikan di luar konteks transaksi
  customerId    String? // null untuk walk-in tanpa registrasi
  rating        Int // 1..5
  comment       String? // catatan opsional dari pelanggan/kasir
  submittedById String? // user.id yang submit (kasir/admin)
  // === Moderation & Auto-Action (iter 2 2026-05-15) ===
  ticketId      String? // link ke ticket yang auto-dibuat saat rating <=2
  // publishStatus: 'pending' (default, tidak public), 'published' (tampil di /book), 'hidden' (admin sembunyikan)
  publishStatus String    @default("pending")
  publishedAt   DateTime?
  publishedById String? // admin yang approve untuk testimoni public
  createdAt     DateTime  @default(now())
  barber        User      @relation("BarberRatings", fields: [barberId], references: [id])

  @@unique([transactionId, barberId])
  @@index([tenantId, createdAt])
  @@index([barberId, createdAt])
  @@index([branchId, createdAt])
  @@index([tenantId, publishStatus]) // untuk query public testimoni cepat
}

// Rating "barbershop" overall yang diisi pelanggan via halaman publik
// (/rating/:transactionId). Satu transaksi punya maksimum satu ShopRating;
// per-barber rating tetap pakai BarberRating. Submission via public link →
// tidak butuh auth, jadi ada audit IP/UA untuk anti-spam ringan.
model ShopRating {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String
  transactionId String   @unique
  customerId    String?
  rating        Int // 1..5 keseluruhan toko
  comment       String? // opsional dari pelanggan
  // Anti-spam audit ringan — kalau ada IP yang submit > N kali dlm 1 jam,
  // operator bisa investigasi via /admin/ratings.
  ipAddress     String?
  userAgent     String?  @db.VarChar(500)
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([branchId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorName String
  action    String
  target    String
  detail    String?
  severity  String   @default("info")
  createdAt DateTime @default(now())
}

// Key-value store for system-wide settings (e.g. Duitku credentials)
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Tracks payment orders created via Duitku
model PaymentOrder {
  id              String               @id @default(cuid())
  merchantOrderId String               @unique
  // Idempotency: jika frontend kirim key yang sama, kembalikan order existing
  // alih-alih membuat baru (mencegah double-charge dari double-click).
  idempotencyKey  String?              @unique
  tenantId        String
  invoiceId       String?
  subscriptionId  String?
  type            String // subscription | branch_addon | upgrade
  targetPackage   SubscriptionPackage? // diisi hanya untuk type=upgrade — paket tujuan
  billingCycle    BillingCycle? // monthly | annual untuk subscription/upgrade
  promotionCode   String?
  discountAmount  Int                  @default(0)
  amount          Int // total final yang dibayar (sudah dikurangi diskon)
  status          String               @default("pending") // pending | success | failed | expired | cancelled
  paymentUrl      String?
  reference       String?
  paymentMethod   String?
  expiresAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

// Promo / kupon — super_admin yang membuat, tenant_admin yang redeem.
model Promotion {
  id            String                @id @default(cuid())
  code          String                @unique
  description   String?
  discountType  String // percent | flat
  discountValue Int // jika percent: 0-100. jika flat: nominal IDR.
  validFrom     DateTime?
  validUntil    DateTime?
  maxUses       Int? // total redemption maksimum (null = unlimited)
  usedCount     Int                   @default(0)
  // Kosong = berlaku semua. Diisi = hanya berlaku pada nilai-nilai yang terdaftar.
  appliesTo     String[]              @default([]) // 'subscription' | 'upgrade' | 'branch_addon'
  packageScope  String[]              @default([]) // 'Basic' | 'Pro' | 'Enterprise'
  cycleScope    String[]              @default([]) // 'monthly' | 'annual'
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  redemptions   PromotionRedemption[]
}

model PromotionRedemption {
  id              String    @id @default(cuid())
  promotionId     String
  tenantId        String
  paymentOrderId  String?
  invoiceId       String?
  discountApplied Int       @default(0)
  redeemedAt      DateTime  @default(now())
  promotion       Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([promotionId])
}

// Konten landing page yang dikelola super_admin.
model LandingTestimonial {
  id           String   @id @default(cuid())
  name         String
  role         String? // jabatan pemilik
  businessName String? // nama barbershop
  message      String
  rating       Int      @default(5) // 1-5
  photoUrl     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LandingFAQ {
  id           String   @id @default(cuid())
  question     String
  answer       String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ErrorLog {
  id         String    @id @default(cuid())
  level      String    @default("error")
  type       String    @default("api_error")
  message    String
  stack      String?
  path       String?
  method     String?
  statusCode Int?
  tenantId   String?
  userId     String?
  metadata   Json?
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())
}

// ── Absensi digital ──────────────────────────────────────────────────────────
// Catatan kehadiran harian satu staf (kasir/barber). Satu baris per staf per
// hari kalender (zona waktu tenant). Lokasi check-in/out divalidasi geofence
// terhadap koordinat cabang. Status & menit terlambat diturunkan dari
// WorkSchedule staf pada hari tersebut.
model Attendance {
  id                String    @id @default(cuid())
  tenantId          String
  branchId          String?
  staffId           String
  // Snapshot identitas staf saat absen — audit trail tetap valid walau user
  // di-rename / di-deactivate / pindah cabang.
  staffName         String?
  staffRole         String?
  // Tanggal kalender (UTC-midnight, mewakili hari lokal tenant).
  date              DateTime
  checkInAt         DateTime?
  checkOutAt        DateTime?
  checkInLat        Float?
  checkInLng        Float?
  checkInDistance   Float? // meter dari titik cabang saat check-in
  checkInPhoto      String? // URL foto selfie check-in (bila requireSelfie aktif)
  checkOutLat       Float?
  checkOutLng       Float?
  checkOutDistance  Float?
  checkOutPhoto     String?
  // present | late | absent | leave  — 'absent'/'leave' bisa diisi manual admin.
  status            String    @default("present")
  lateMinutes       Int       @default(0)
  earlyLeaveMinutes Int       @default(0)
  workedMinutes     Int? // checkOut - checkIn (menit)
  // Snapshot jadwal kerja efektif hari itu — supaya rekap historis tak berubah
  // saat admin mengedit WorkSchedule di kemudian hari.
  scheduleStart     String?
  scheduleEnd       String?
  note              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  staff             User      @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([tenantId, date])
  @@index([branchId, date])
}

// Jadwal kerja mingguan per staf — acuan perhitungan terlambat & pulang cepat.
// Satu baris per (staf, hari) — dayOfWeek 0=Minggu .. 6=Sabtu.
model WorkSchedule {
  id        String   @id @default(cuid())
  tenantId  String
  staffId   String
  dayOfWeek Int
  isDayOff  Boolean  @default(false)
  startTime String   @default("09:00")
  endTime   String   @default("17:00")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff     User     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([tenantId])
}

// ── Affiliate Program ─────────────────────────────────────────────────────
// Mitra affiliate (role=affiliate). Mereka membawa pelanggan baru (tenant)
// via referralCode unik, dapat komisi % dari setiap invoice yang dibayar
// tenant rujukan. Saldo dicairkan via permintaan payout manual yang di-approve
// super-admin.

enum AffiliateStatus {
  pending // baru daftar, menunggu approval super-admin
  active  // approved, link rujukan aktif
  suspended // dibekukan sementara — link tetap valid tapi komisi tak akumulasi
  rejected // permohonan ditolak
}

enum AffiliateCommissionStatus {
  pending  // baru tercatat, belum bisa dicairkan
  approved // dianggap valid, masuk ke saldo dapat-ditarik
  paid     // sudah dibayarkan ke affiliate via payout
  void     // dibatalkan (refund/chargeback/fraud)
}

enum AffiliatePayoutStatus {
  requested  // affiliate ajukan payout, menunggu super-admin
  processing // super-admin mulai proses
  paid       // sudah terbayar
  rejected   // ditolak
}

model Affiliate {
  id              String         @id @default(cuid())
  // Tautan ke User. 1-1 — satu profil affiliate punya satu akun login.
  userId          String         @unique
  // Kode rujukan unik. Pendek, uppercase, dipakai di URL `?ref=XXXX`.
  referralCode    String         @unique
  // Persentase komisi yang dipakai untuk tenant baru yang dirujuk affiliate ini.
  // Disnapshot ke AffiliateCommission saat invoice dibayar — agar perubahan
  // rate tidak retroaktif.
  commissionRate  Float          @default(0.10) // 10%
  status          AffiliateStatus @default(pending)
  // Profil tampil & komunikasi — disinkronkan dari User.name/email/phone saat
  // approval; field di sini boleh berbeda (misal nama panggilan publik).
  displayName     String?
  bio             String?
  // Metode pencairan saldo. method ∈ 'bank_transfer' | 'gopay' | 'ovo' | 'dana'.
  payoutMethod    String?
  payoutAccount   String? // no rekening / no e-wallet
  payoutHolder    String? // nama pemilik rekening
  // Catatan internal super-admin (tidak ditampilkan ke affiliate).
  internalNotes   String?
  // Cache total earning untuk dashboard cepat. Dihitung ulang setiap commission
  // di-approve/paid/void via $transaction.
  totalEarned     Int            @default(0) // semua approved+paid
  totalPaid       Int            @default(0) // sudah ditransfer
  approvedAt      DateTime?
  suspendedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation("UserAffiliate", fields: [userId], references: [id], onDelete: Cascade)
  referrals       AffiliateReferral[]
  commissions     AffiliateCommission[]
  payouts         AffiliatePayout[]

  @@index([status, createdAt])
}

model AffiliateReferral {
  id           String     @id @default(cuid())
  affiliateId  String
  // 1-1 dengan Tenant — satu tenant maksimum direkrut oleh satu affiliate.
  tenantId     String     @unique
  // Snapshot kode rujukan yang dipakai saat tenant daftar — supaya histori
  // tetap valid bila affiliate kelak ganti kode.
  referralCode String
  // 'active'  — masih membayar & komisi berjalan; 'churned' — langganan habis;
  // 'pending' — klaim manual menunggu persetujuan super-admin (KOMISI BELUM
  // jalan sampai disetujui); 'rejected' — klaim manual ditolak admin.
  status       String     @default("active")
  // Asal rujukan: 'link' (otomatis dari ?ref= saat tenant daftar) atau
  // 'manual' (affiliate mengklaim tenant yang sudah daftar tanpa link-nya).
  source       String     @default("link")
  // Alasan/keterangan affiliate saat mengajukan klaim manual.
  claimNote    String?
  // Catatan super-admin saat menyetujui/menolak klaim manual.
  reviewNote   String?
  reviewedAt   DateTime?
  reviewedById String?
  // Cache jumlah komisi yang sudah dihasilkan tenant ini — dipakai per-baris
  // di tabel referrals dashboard tanpa N+1.
  totalCommission Int     @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  affiliate    Affiliate  @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  commissions  AffiliateCommission[]

  @@index([affiliateId, createdAt])
}

model AffiliateCommission {
  id              String   @id @default(cuid())
  affiliateId     String
  referralId      String
  tenantId        String
  // Sumber invoice yang men-trigger komisi. invoiceId nullable untuk audit
  // bukti payment_order, tapi seharusnya selalu terisi pada flow normal.
  invoiceId       String?
  paymentOrderId  String?
  // Nominal dasar (amount invoice setelah diskon promo) — basis hitung komisi.
  baseAmount      Int
  // Persentase komisi snapshot saat invoice dibayar (decimal, e.g. 0.10).
  commissionRate  Float
  // Komisi final dalam IDR (= round(baseAmount * commissionRate)).
  amount          Int
  status          AffiliateCommissionStatus @default(pending)
  // Periode invoice — untuk tampilan ringkas di dashboard.
  period          String?
  // Diisi saat status berubah ke 'paid' (oleh payout).
  payoutId        String?
  paidAt          DateTime?
  // Catatan kalau status=void (alasan pembatalan).
  voidReason      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  affiliate       Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referral        AffiliateReferral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  payout          AffiliatePayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@unique([invoiceId, affiliateId]) // 1 invoice → 1 commission per affiliate
  @@index([affiliateId, status, createdAt])
  @@index([referralId, createdAt])
}

model AffiliatePayout {
  id            String   @id @default(cuid())
  affiliateId   String
  amount        Int
  method        String   // snapshot dari Affiliate.payoutMethod saat request
  account       String
  holder        String?
  status        AffiliatePayoutStatus @default(requested)
  // Catatan affiliate (mis. "Mohon transfer secepatnya") & catatan admin.
  affiliateNote String?
  adminNote     String?
  // Identitas super-admin yang memproses — untuk audit.
  processedById String?
  processedAt   DateTime?
  // Bukti transfer (URL gambar) — diunggah saat status berubah ke paid.
  proofUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  commissions   AffiliateCommission[]

  @@index([affiliateId, createdAt])
  @@index([status, createdAt])
}

// Log pesan WhatsApp keluar per tenant — sumber data halaman
// /admin/whatsapp-logs (memantau pesan terkirim/gagal). Dicatat best-effort di
// whatsappService.dispatchMessage; status diperbarui dari webhook gateway
// (message.sent/delivered/failed). Bersifat observabilitas — kegagalan
// menyimpan log TIDAK boleh mengganggu pengiriman pesan.
model WhatsappMessageLog {
  id           String    @id @default(cuid())
  tenantId     String
  // messageId dari gateway — dicocokkan saat webhook memperbarui status.
  messageId    String?
  recipient    String    // nomor tujuan ter-normalisasi (62...)
  // transaction_admin | transaction_customer | rating | test | system
  category     String    @default("system")
  // queued | sent | delivered | read | failed | skipped
  status       String    @default("sent")
  // Alasan gagal/skip atau pesan error gateway (not_connected, invalid_phone, ...).
  reason       String?
  // Potongan isi pesan (~120 char) untuk memudahkan penelusuran.
  preview      String?
  // Isi pesan lengkap — dipakai untuk fitur "kirim ulang" verbatim. Null untuk
  // baris lama (sebelum fitur ini) sehingga tak bisa di-resend.
  body         String?   @db.Text
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([messageId])
}
